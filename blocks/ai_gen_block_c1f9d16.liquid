{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-list-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.section_bg_color }};
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-product-list-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.gap_desktop }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  @media screen and (max-width: 989px) {
    .ai-product-list-container-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.75 }}px {{ block.settings.section_padding_horizontal | times: 0.75 }}px {{ block.settings.section_padding_bottom | times: 0.75 }}px;
    }

    .ai-product-list-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
      gap: {{ block.settings.gap_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-list-container-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.5 }}px {{ block.settings.section_padding_horizontal | times: 0.5 }}px {{ block.settings.section_padding_bottom | times: 0.5 }}px;
    }

    .ai-product-list-{{ ai_gen_id }} {
      {% if block.settings.products_per_row_mobile == 1 %}
        grid-template-columns: 1fr;
      {% else %}
        grid-template-columns: repeat(2, 1fr);
      {% endif %}
      gap: {{ block.settings.gap_mobile }}px;
    }
  }

  .ai-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: all {{ block.settings.hover_transition_speed }}s ease;
    {% if block.settings.card_border_width > 0 %}
      border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    {% endif %}
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    {% if block.settings.enable_hover_shadow %}
      box-shadow: {{ block.settings.hover_shadow_x }}px {{ block.settings.hover_shadow_y }}px {{ block.settings.hover_shadow_blur }}px {{ block.settings.hover_shadow_spread }}px {{ block.settings.hover_shadow_color }};
    {% endif %}
    {% if block.settings.enable_hover_scale %}
      transform: scale({{ block.settings.hover_scale }});
    {% endif %}
    {% if block.settings.enable_hover_lift %}
      transform: translateY(-{{ block.settings.hover_lift_distance }}px);
    {% endif %}
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: {{ block.settings.image_bg_color }};
    border-radius: {{ block.settings.image_border_radius }}px {{ block.settings.image_border_radius }}px 0 0;
  }

  .ai-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_fit }};
    object-position: {{ block.settings.image_position }};
    transition: transform {{ block.settings.hover_transition_speed }}s ease;
  }

  {% if block.settings.enable_image_hover_zoom %}
    .ai-product-card-{{ ai_gen_id }}:hover .ai-product-image-{{ ai_gen_id }} {
      transform: scale({{ block.settings.image_hover_zoom_scale }});
    }
  {% endif %}

  .ai-product-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-product-info-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.75 }}px;
      gap: {{ block.settings.text_gap | times: 0.75 }}px;
    }
  }

  .ai-product-brand-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_font_size }}px;
    color: {{ block.settings.brand_color }};
    text-transform: {{ block.settings.brand_text_transform }};
    letter-spacing: {{ block.settings.brand_letter_spacing }}px;
    font-weight: {{ block.settings.brand_font_weight }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    font-weight: {{ block.settings.title_font_weight }};
    line-height: {{ block.settings.title_line_height }};
    text-transform: {{ block.settings.title_text_transform }};
  }

  .ai-product-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: {{ block.settings.description_line_height }};
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: {{ block.settings.price_font_weight }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-product-brand-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.brand_font_size }}px * 0.9);
    }

    .ai-product-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_font_size }}px * 0.9);
    }

    .ai-product-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_font_size }}px * 0.9);
    }

    .ai-product-price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.price_font_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-brand-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.brand_font_size }}px * 0.8);
    }

    .ai-product-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_font_size }}px * 0.8);
    }

    .ai-product-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_font_size }}px * 0.8);
    }

    .ai-product-price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.price_font_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-product-list-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-list-{{ ai_gen_id }}">
    {% for product in block.settings.products %}
      <a href="{{ product.url }}" class="ai-product-card-{{ ai_gen_id }}">
        <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
          {% if product.featured_image %}
            <img
              src="{{ product.featured_image | image_url: width: 600 }}"
              srcset="{{ product.featured_image | image_url: width: 300 }} 300w,
                      {{ product.featured_image | image_url: width: 600 }} 600w,
                      {{ product.featured_image | image_url: width: 900 }} 900w,
                      {{ product.featured_image | image_url: width: 1200 }} 1200w"
              sizes="(max-width: 749px) 50vw,
                     (max-width: 989px) 33vw,
                     25vw"
              alt="{{ product.featured_image.alt | escape }}"
              class="ai-product-image-{{ ai_gen_id }}"
              loading="lazy"
              width="600"
              height="600"
            >
          {% else %}
            <div class="ai-product-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        <div class="ai-product-info-{{ ai_gen_id }}">
          {% if block.settings.show_brand and product.vendor != blank %}
            <p class="ai-product-brand-{{ ai_gen_id }}">{{ product.vendor }}</p>
          {% endif %}
          <h3 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
          {% if block.settings.show_description and product.description != blank %}
            <p class="ai-product-description-{{ ai_gen_id }}">
              {{ product.description | strip_html | truncate: block.settings.description_length }}
            </p>
          {% endif %}
          <p class="ai-product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
        </div>
      </a>
    {% endfor %}
  </div>
</div>


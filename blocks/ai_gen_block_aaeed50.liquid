{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-list-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-product-list-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-product-list-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 989px) {
    .ai-product-list-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-list-grid-{{ ai_gen_id }} {
      {% if block.settings.products_per_row_mobile == '1' %}
        grid-template-columns: 1fr;
      {% else %}
        grid-template-columns: repeat(2, 1fr);
      {% endif %}
    }
  }

  .ai-product-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border: 1px solid transparent;
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: all 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.border_hover_color }};
  }

  .ai-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: {{ block.settings.image_bg_color }};
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.content_spacing }}px;
  }

  .ai-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .ai-product-card-{{ ai_gen_id }}:hover .ai-product-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.image_bg_color }};
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-product-brand-{{ ai_gen_id }} {
    font-size: {{ block.settings.brand_font_size }}px;
    font-weight: {{ block.settings.brand_font_weight }};
    color: {{ block.settings.brand_color }};
    text-transform: {{ block.settings.brand_text_transform }};
    letter-spacing: {{ block.settings.brand_letter_spacing }}px;
    margin: 0;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-product-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    font-weight: {{ block.settings.price_font_weight }};
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    margin-left: 8px;
  }

  .ai-product-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: {{ block.settings.description_color }};
    font-size: {{ block.settings.description_font_size }}px;
  }
{% endstyle %}

<div class="ai-product-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-list-container-{{ ai_gen_id }}">
    {% if block.settings.products.count > 0 %}
      <div class="ai-product-list-grid-{{ ai_gen_id }}">
        {% for product in block.settings.products %}
          <a href="{{ product.url }}" class="ai-product-card-{{ ai_gen_id }}">
            <div class="ai-product-image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                          {{ product.featured_image | image_url: width: 600 }} 600w,
                          {{ product.featured_image | image_url: width: 800 }} 800w,
                          {{ product.featured_image | image_url: width: 1000 }} 1000w"
                  sizes="(max-width: 749px) {% if block.settings.products_per_row_mobile == '1' %}100vw{% else %}50vw{% endif %},
                         (max-width: 989px) calc(100vw / {{ block.settings.products_per_row_tablet }}),
                         calc({{ block.settings.max_width }}px / {{ block.settings.products_per_row }})"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-product-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {% else %}
                <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            <div class="ai-product-content-{{ ai_gen_id }}">
              {% if block.settings.show_brand and product.vendor != blank %}
                <div class="ai-product-brand-{{ ai_gen_id }}">{{ product.vendor }}</div>
              {% endif %}

              {% if block.settings.show_title %}
                <h3 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
              {% endif %}

              {% if block.settings.show_description and product.description != blank %}
                <div class="ai-product-description-{{ ai_gen_id }}">
                  {{ product.description | strip_html | truncate: block.settings.description_length }}
                </div>
              {% endif %}

              {% if block.settings.show_price %}
                <div class="ai-product-price-{{ ai_gen_id }}">
                  {% if product.compare_at_price > product.price %}
                    <span>{{ product.price | money }}</span>
                    <span class="ai-product-price-compare-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                  {% else %}
                    {{ product.price | money }}
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-product-empty-state-{{ ai_gen_id }}">
        Next, add products to display in this list
      </div>
    {% endif %}
  </div>
</div>

